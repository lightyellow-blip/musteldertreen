generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 문의
model Inquiry {
  id        String   @id @default(cuid())
  status    String   @default("pending") // pending | in_progress | completed
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  fileUrl   String?
  fileName  String?

  // 답변 정보
  replySubject String?   // 답변 이메일 제목
  replyMessage String?   // 답변 내용
  repliedAt    DateTime? // 답변 발송 일시
  repliedBy    String?   // 답변한 관리자 이름

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// 메뉴
model Menu {
  id        String    @id @default(cuid())
  label     String
  href      String
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  parentId  String?
  parent    Menu?     @relation("MenuToMenu", fields: [parentId], references: [id], onDelete: Cascade)
  children  Menu[]    @relation("MenuToMenu")
  sections  Section[] // 메뉴에 연결된 섹션들
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([parentId])
  @@index([order])
}

// 섹션 (메뉴에 연결)
model Section {
  id        String    @id @default(cuid())
  name      String
  order     Int       @default(0)
  menuId    String
  menu      Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  contents  Content[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([menuId])
  @@index([order])
}

// 콘텐츠
model Content {
  id        String   @id @default(cuid())
  type      String   // text | image | video | gallery
  title     String
  data      Json     @default("{}")
  order     Int      @default(0)
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
  @@index([order])
}

// 관리자
model Admin {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String   // bcrypt 해시
  name        String
  role        String   @default("ADMIN") // SUPER_ADMIN | ADMIN
  permissions Json     @default("[]")    // ["menus", "contents", "inquiries", "analytics", "settings"]
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([role])
}

// 사이트 설정
model Settings {
  id               String @id @default("site")
  siteName         String @default("")
  siteDescription  String @default("")
  logoUrl          String @default("")
  faviconUrl       String @default("")
  footerText       String @default("")
  address          String @default("")
  phone            String @default("")
  email            String @default("")
  businessHours    String @default("")
  instagram        String @default("")
  facebook         String @default("")
  youtube          String @default("")
  blog             String @default("")
  metaTitle        String @default("")
  metaDescription  String @default("")
  metaKeywords     String @default("")
  googleAnalyticsId String @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// IP 화이트리스트
model IpWhitelist {
  id          String   @id @default(cuid())
  ip          String   @unique
  description String?  // IP 설명 (예: 본사, 지사 등)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ip])
  @@index([isActive])
}
